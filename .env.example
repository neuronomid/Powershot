# Powershot environment variables.
# Copy to .env.local for local dev. Never commit .env.local.

# OpenRouter API key — server-side only. Do NOT prefix with NEXT_PUBLIC_.
# Used by /api/extract, /api/dedup, and /api/review.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# NOWPayments API key — server-side only. Do NOT prefix with NEXT_PUBLIC_.
# Used by /api/donate/* routes for crypto donation processing.
# https://nowpayments.io/dashboard/api-keys
NOWPAYMENTS_API_KEY=

# NOWPayments IPN secret key — server-side only. Used to verify callback signatures.
# Generated in the NOWPayments dashboard under Payment Settings.
NOWPAYMENTS_IPN_SECRET=

# PayPal donation URL — client-safe (NEXT_PUBLIC_ prefix required for browser access).
# Create your donate link at https://www.paypal.com/donate/buttons
NEXT_PUBLIC_PAYPAL_DONATE_URL=
