{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "ES2022", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "vite.config.ts", "../src/lib/intake/messages.ts"]
}
